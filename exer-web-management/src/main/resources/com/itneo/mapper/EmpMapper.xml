<!--定义Mapper映射文件的约束和基本结构-->
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itneo.mapper.EmpMapper">

    <!--根据ID更新员工基本信息-->
    <update id="updateById">
            UPDATE emp
            <set>
                <if test="username != null and username != ''">username = #{username},</if>
                <if test="password != null and password != ''">password = #{password},</if>
                <if test="name != null and name != ''">name = #{name},</if>
                <if test="gender != null">gender = #{gender},</if>
                <if test="phone != null and phone != ''">phone = #{phone},</if>
                <if test="exerType != null">exer_type = #{exerType},</if>
                <if test="burnCalorie != null">burn_calorie = #{burnCalorie},</if>
                <if test="image != null and image != ''">image = #{image},</if>
                <if test="entryDate != null">entry_date = #{entryDate},</if>
                <if test="locationId != null">location_id = #{locationId},</if>
                <if test="updateTime != null">update_time = #{updateTime},</if>
            </set>
            WHERE id = #{id}
    </update>

    <!--批量删除员工基本信息-->
    <delete id="deleteByIds">
        delete from emp where id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>

    <select id="list" resultType="com.itneo.pojo.Emp">
        select e.id, e.username, e.password, e.name, e.gender, e.phone, e.exer_type, e.burn_calorie,
        e.image, e.entry_date, e.location_id, e.create_time, e.update_time, l.name locationName
        from emp e left join location l on e.location_id = l.id
        <where>
            <if test="name != null and name != ''">
                e.name like concat('%',#{name},'%')
            </if>
            <if test="gender != null">
                and e.gender = #{gender}
            </if>
            <if test="begin != null and end != null">
                and e.entry_date between #{begin} and #{end}
            </if>
        </where>
        order by e.update_time desc
    </select>

    <!--自定义结果集ResultMap-->
    <resultMap id="empResultMap" type="com.itneo.pojo.Emp">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="name" property="name" />
        <result column="gender" property="gender" />
        <result column="phone" property="phone" />
        <result column="exer_type" property="exerType" />
        <result column="burn_calorie" property="burnCalorie" />
        <result column="image" property="image" />
        <result column="entry_date" property="entryDate" />
        <result column="location_id" property="locationId" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />

        <!--封装exprList-->
        <collection property="exprList" ofType="com.itneo.pojo.EmpExpr">
            <id column="ee_id" property="id"/>
            <result column="ee_company" property="company"/>
            <result column="ee_exertype" property="exerType"/>
            <result column="ee_begin" property="begin"/>
            <result column="ee_end" property="end"/>
            <result column="ee_empid" property="empId"/>
        </collection>
    </resultMap>

    <!--根据id查询员工基本信息以及员工锻炼经历-->
    <select id="getInfo" resultMap="empResultMap">
        select
            e.*,
            ee.id ee_id,
            ee.emp_id ee_empid,
            ee.begin ee_begin,
            ee.end ee_end,
            ee.company ee_company,
            ee.exer_type ee_exertype
        from emp e left join emp_expr ee on e.id = ee.emp_id where e.id = #{id}
    </select>

    <!--统计员工锻炼方式的人数-->
    <select id="countEmpEmpTypeData" resultType="java.util.Map">
        select
            (case when exer_type = 1 then '核心训练'
                  when exer_type = 2 then '有氧训练'
                  when exer_type = 3 then '燃脂训练'
                  when exer_type = 4 then '普拉提锻炼'
                  when exer_type = 5 then '拉伸放松'
                  else '其他' end) pos,
            count(*) num
        from emp group by exer_type order by num
    </select>

    <!--统计员工性别人数-->
    <select id="countEmpGenderData" resultType="java.util.Map">
        select
            if(gender=1, '男性员工', '女性员工') name,
            count(*) value
        from emp group by gender
    </select>
</mapper>